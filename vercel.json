{
  "version": 2,
  "name": "share2inspire",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/pages/cv-analyser",
      "destination": "/cv-analyser",
      "permanent": true
    },
    {
      "source": "/pages/cv-analysis",
      "destination": "/cv-analyser",
      "permanent": true
    },
    {
      "source": "/cv-builder",
      "destination": "https://cv-builder.share2inspire.pt",
      "permanent": true
    },
    {
      "source": "/cv-builder/:path*",
      "destination": "https://cv-builder.share2inspire.pt/:path*",
      "permanent": true
    }
  ],
  "routes": [
    {
      "src": "/cv-analyser/assets/(.*)",
      "dest": "/cv-analyser/assets/$1"
    },
    {
      "src": "/cv-analyser/(.*)",
      "dest": "/cv-analyser/index.html"
    },
    {
      "handle": "filesystem"
    }
  ]
}
