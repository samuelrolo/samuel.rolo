{
  "version": 2,
  "name": "share2inspire",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/pages/cv-analyser",
      "destination": "/cv-analyser",
      "permanent": true
    },
    {
      "source": "/pages/cv-analysis",
      "destination": "/cv-analyser",
      "permanent": true
    },
    {
      "source": "/cv-builder",
      "destination": "https://cv-builder.share2inspire.pt",
      "permanent": true
    },
    {
      "source": "/cv-builder/:path*",
      "destination": "https://cv-builder.share2inspire.pt/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/cv-analyser",
      "destination": "/cv-analyser/index.html"
    },
    {
      "source": "/cv-analyser/:path*",
      "destination": "/cv-analyser/index.html"
    },
    {
      "source": "/career-path",
      "destination": "/career-path/index.html"
    },
    {
      "source": "/career-path/:path*",
      "destination": "/career-path/index.html"
    },
    {
      "source": "/en/cv-analyser",
      "destination": "/en/cv-analyser/index.html"
    },
    {
      "source": "/en/cv-analyser/:path*",
      "destination": "/en/cv-analyser/index.html"
    },
    {
      "source": "/en/career-path",
      "destination": "/en/career-path/index.html"
    },
    {
      "source": "/en/career-path/:path*",
      "destination": "/en/career-path/index.html"
    }
  ]
}
