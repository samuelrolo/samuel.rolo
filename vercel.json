{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "share2inspire",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/interview-scripts",
      "destination": "/loja#script-entrevistas",
      "permanent": false
    },
    {
      "source": "/en/interview-scripts",
      "destination": "/loja#script-entrevistas",
      "permanent": false
    },
    {
      "source": "/pages/cv-analyser",
      "destination": "/cv-analyser",
      "permanent": true
    },
    {
      "source": "/pages/cv-analysis",
      "destination": "/cv-analyser",
      "permanent": true
    },
    {
      "source": "/pages/services",
      "destination": "/en/pages/services",
      "permanent": false
    },
    {
      "source": "/cv-builder",
      "destination": "https://cv-builder.share2inspire.pt",
      "permanent": true
    },
    {
      "source": "/cv-builder/:path*",
      "destination": "https://cv-builder.share2inspire.pt/:path*",
      "permanent": true
    },
    {
      "source": "/artigos/como-negociar-salario-portugal",
      "destination": "/blog/artigos/como-negociar-salario-portugal",
      "permanent": true
    },
    {
      "source": "/en/artigos/how-to-negotiate-salary",
      "destination": "/en/blog/artigos/how-to-negotiate-salary",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/(cv-analyser|career-path|career-intelligence|bundle|linkedin-roaster|area-cliente|en/cv-analyser|en/career-path|en/career-intelligence|en/bundle|en/linkedin-roaster)(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/cv-analyser/llms.txt",
      "destination": "/cv-analyser/llms.txt"
    },
