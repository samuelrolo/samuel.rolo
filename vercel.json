{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "share2inspire",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/pages/cv-analyser",
      "destination": "/cv-analyser",
      "permanent": true
    },
    {
      "source": "/pages/cv-analysis",
      "destination": "/cv-analyser",
      "permanent": true
    },
    {
      "source": "/pages/services",
      "destination": "/en/pages/services",
      "permanent": false
    },
    {
      "source": "/cv-builder",
      "destination": "https://cv-builder.share2inspire.pt",
      "permanent": true
    },
    {
      "source": "/cv-builder/:path*",
      "destination": "https://cv-builder.share2inspire.pt/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/cv-analyser/llms.txt",
      "destination": "/cv-analyser/llms.txt"
    },
    {
      "source": "/career-path/llms.txt",
      "destination": "/career-path/llms.txt"
    },
    {
      "source": "/en/cv-analyser/llms.txt",
      "destination": "/en/cv-analyser/llms.txt"
    },
    {
      "source": "/en/career-path/llms.txt",
      "destination": "/en/career-path/llms.txt"
    },
    {
      "source": "/en/pages/about",
      "destination": "/en/pages/about/index.html"
    },
    {
      "source": "/en/pages/home",
      "destination": "/en/pages/home/index.html"
    },
    {
      "source": "/en/pages/services",
      "destination": "/en/pages/services/index.html"
    },
    {
      "source": "/en/pages/privacy-policy",
      "destination": "/en/pages/privacy-policy/index.html"
    },
    {
      "source": "/en/pages/contact",
      "destination": "/en/pages/contact/index.html"
    },
    {
      "source": "/cv-analyser",
      "destination": "/cv-analyser/index.html"
    },
    {
      "source": "/cv-analyser/(.*)",
      "destination": "/cv-analyser/index.html"
    },
    {
      "source": "/career-path",
      "destination": "/career-path/index.html"
    },
    {
      "source": "/career-path/(.*)",
      "destination": "/career-path/index.html"
    },
    {
      "source": "/en/cv-analyser",
      "destination": "/en/cv-analyser/index.html"
    },
    {
      "source": "/en/cv-analyser/(.*)",
      "destination": "/en/cv-analyser/index.html"
    },
    {
      "source": "/en/career-path",
      "destination": "/en/career-path/index.html"
    },
    {
      "source": "/en/career-path/(.*)",
      "destination": "/en/career-path/index.html"
    }
  ]
}
